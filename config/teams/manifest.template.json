{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.21/MicrosoftTeams.schema.json",
  "manifestVersion": "1.21",
  "version": "0.1.0",
  "id": "${TEAMS_APP_ID}",
  "developer": {
    "name": "SAT / Meeting Knowledge Hub",
    "websiteUrl": "${PUBLIC_BASE_URL}",
    "privacyUrl": "${PUBLIC_BASE_URL}/privacy",
    "termsOfUseUrl": "${PUBLIC_BASE_URL}/terms"
  },
  "name": {
    "short": "SAT Secretary BOT",
    "full": "SAT Secretary BOT for Meeting Knowledge Hub"
  },
  "description": {
    "short": "AI meeting secretary for captions and transcript capture.",
    "full": "SAT Secretary BOT joins approved Microsoft Teams meetings as a visible participant, supports Japanese captions, transcript capture, preview workflows, and post-meeting knowledge processing."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#2563EB",
  "bots": [
    {
      "botId": "${TEAMS_BOT_ID}",
      "scopes": ["personal", "team", "groupchat"],
      "supportsFiles": false,
      "isNotificationOnly": false
    }
  ],
  "configurableTabs": [
    {
      "configurationUrl": "${PUBLIC_BASE_URL}/teams/config",
      "canUpdateConfiguration": true,
      "scopes": ["team", "groupchat"],
      "context": ["meetingChatTab", "meetingDetailsTab", "meetingSidePanel"]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["${PUBLIC_DOMAIN}"],
  "webApplicationInfo": {
    "id": "${ENTRA_CLIENT_ID}",
    "resource": "api://${PUBLIC_DOMAIN}/${ENTRA_CLIENT_ID}"
  }
}
